FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

RUN npm ci --omit=dev && npm cache clean --force

COPY services/auth ./services/auth
COPY routes/authRoutes.js ./routes/authRoutes.js
COPY controllers/authController.js ./controllers/authController.js
COPY middleware ./middleware
COPY utils ./utils
COPY config ./config
COPY models ./models

ENV NODE_ENV=production

ENV PORT=3001

EXPOSE 3001

CMD ["node", "services/auth/server.js"]

