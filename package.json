    "express-graphql": "^0.12.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "graphql": "^15.10.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
